{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022"],
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"types": ["node"],
		"allowImportingTsExtensions": true,
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true
	},
	"include": ["index.ts", "src/**/*.ts", "test/**/*.ts"]
}
